{
  "version": 2,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/cron/daily", "schedule": "30 18 * * *" },
    { "path": "/api/cron/weekly", "schedule": "30 18 * * 0" }
  ]
}
